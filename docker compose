  fishtest_logger:
    build: .
    container_name: fishtest_logger
    restart: always
    command: python fishtest_monitor.py
    volumes:
      - .:/app
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      - PYTHONUNBUFFERED=1
      - DB_HOST=postgres_db
      - DB_NAME=fishtest
      - DB_USER=
      - DB_PASS=""
    depends_on:
      - postgres_db
    networks:
      - fishnet_net
